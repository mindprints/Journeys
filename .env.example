# Required for AI topic suggestions endpoint and AI-Model content generation
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model used by the AI-Model source adapter (scripts/python/sources/aimodel.py)
# Defaults to openai/gpt-4o-mini if not set
OPENROUTER_CONTENT_MODEL=openai/gpt-4o-mini

# Image generation model used whenever AI generates poster content
# (Wikipedia disambiguation fallback + AI-Model source). Saved to images/originals/
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview

# Optional override for topic-suggestion model (POST /api/ai/topic-suggestions)
OPENROUTER_TOPIC_MODEL=minimax/minimax-m2.7

# Optional legacy alias (used as fallback by server.js)
OPENROUTER_MODEL=z-ai/glm-5-turbo

# Optional, reserved for future Artificial Analysis API integrations
ARTIFICIAL_ANALYSIS_API_KEY=your_artificial_analysis_api_key_here
